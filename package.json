{
  "name": "bugscrub",
  "version": "0.0.0",
  "private": true,
  "description": "Schema-driven CLI for exploratory bug scrub workflows.",
  "type": "module",
  "bin": {
    "bugscrub": "./dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm generate:schemas && tsc -p tsconfig.json",
    "commit": "cz",
    "commitlint": "commitlint",
    "dev": "node --import tsx src/index.ts",
    "generate:schemas": "node --import tsx scripts/generate-schemas.ts",
    "prepare": "husky",
    "test": "vitest run",
    "test:open": "vitest --ui --open",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "chalk": "^5.0.0",
    "commander": "^14.0.0",
    "yaml": "^2.0.0",
    "zod": "^4.1.12",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/node": "^22.0.0",
    "@vitest/ui": "^4.0.18",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
